#!/usr/bin/env bash

set -eu

export HOMEBREW_LINUX=1

HOMEBREW_VERSION="$(cat "/usr/lib/homebrew/homebrew-version.txt")"
PKG_VERSION="$(cat "/usr/lib/homebrew/package-version.txt")"
HOMEBREW_ALL_VERSIONS_DIR="${HOME}/.local/share/homebrew"
HOMEBREW_DIR="${HOMEBREW_ALL_VERSIONS_DIR}/${PKG_VERSION}"

if [[ ! -f "${HOMEBREW_DIR}/bin/brew" ]]; then
  echo "Setting up homebrew..."

  TAR_DIR="$(mktemp -d)"
  EXTRACTED_DIR="$(mktemp -d)"

  curl -sSL --output "${TAR_DIR}/homebrew.tar.gz" \
    "https://github.com/Homebrew/brew/archive/refs/tags/${HOMEBREW_VERSION}.tar.gz"

  tar xf "${TAR_DIR}/homebrew.tar.gz" --directory="${EXTRACTED_DIR}"

  rm -rf "${HOMEBREW_ALL_VERSIONS_DIR}"
  mkdir -p "${HOMEBREW_ALL_VERSIONS_DIR}"
  mv "${EXTRACTED_DIR}/$(ls ${EXTRACTED_DIR} | grep brew-*)" "${HOMEBREW_DIR}"

  mkdir -p "${HOMEBREW_DIR}/etc/homebrew"
  echo "HOMEBREW_CELLAR=\"${HOMEBREW_DIR}/Cellar\"" | tee "${HOMEBREW_DIR}/etc/homebrew/brew.env"

  rm -rf "${TAR_DIR}"
  echo "Homebrew set up successfully completed!"
fi

exec "${HOMEBREW_DIR}/bin/brew" "$@"
